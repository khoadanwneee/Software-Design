# Shared
NODE_ENV=development
APP_ORIGIN=http://localhost:5173
API_PORT=4000
JWT_SECRET=change-me-in-local-dev
JWT_EXPIRES_IN=2h
BCRYPT_ROUNDS=10

# Database
DATABASE_URL=postgresql://unihub:unihub@localhost:5432/unihub_workshop?schema=public

# Redis / BullMQ
REDIS_URL=redis://localhost:6379

# Web
VITE_API_BASE_URL=http://localhost:4000/api
VITE_APP_NAME=UniHub Workshop

# Local object storage scaffold
UPLOAD_DIR=./tmp/uploads
MAX_UPLOAD_BYTES=10485760

# Rate limiting thresholds
RATE_LIMIT_DEFAULT_POINTS=120
RATE_LIMIT_DEFAULT_DURATION_SECONDS=60
RATE_LIMIT_REGISTRATION_POINTS=10
RATE_LIMIT_PAYMENT_POINTS=8
RATE_LIMIT_CHECKIN_SYNC_POINTS=30
