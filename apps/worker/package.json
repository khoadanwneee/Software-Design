{
  "name": "@unihub/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "dotenv -e ../../.env -- tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src tests --ext .ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@unihub/db": "workspace:*",
    "@unihub/shared-types": "workspace:*",
    "@unihub/shared-utils": "workspace:*",
    "bullmq": "^5.34.5",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "dotenv-cli": "^11.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
